{
  "name": "AI Check",
  "description": "WebサイトのAI検索対応度をチェックし、llms.txt・robots.txt・JSON-LD構造化データ・agent.jsonを自動生成するツール",
  "url": "https://ai-check.ezoai.jp",
  "version": "1.2.0",
  "capabilities": [
    "GEOスコアチェック（7指標 + llms-full.txt検出 + スキーマタイプ識別）",
    "llms.txt生成",
    "robots.txt生成（AIクローラー対応）",
    "JSON-LD構造化データ生成（6スキーマタイプ対応）",
    "agent.json（A2A Agent Card）生成",
    "複数サイトGEOスコア比較",
    "業界別GEO対策ガイド（EC・SaaS・メディア・士業・ローカル・教育）",
    "API / 開発者向けドキュメント"
  ],
  "endpoints": {
    "mcp": "https://ai-check.ezoai.jp/api/mcp",
    "check": "https://ai-check.ezoai.jp/api/check",
    "generate": "https://ai-check.ezoai.jp/api/generate"
  },
  "mcp_tools": [
    "check_geo_score",
    "generate_llms_txt",
    "generate_robots_txt",
    "generate_json_ld",
    "generate_agent_json"
  ],
  "authentication": {
    "type": "none"
  },
  "protocols": ["mcp", "rest"]
}
